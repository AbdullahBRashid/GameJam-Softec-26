%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 56a93f80ef9b3442ca31310dcc4fcbcf, type: 3}
  m_Name: NarratorLines
  m_EditorClassIdentifier: Assembly-CSharp::NarratorLinesSO
  lines:
  - messageName: inventoryFull
    message: Your pockets are full. Drop something first.
  - messageName: cannotApply
    message: I can't put that there.
  - messageName: doorLocked
    message: It won't budge. Time is standing still.
  - messageName: keyUsed
    message: 'WARNING: Unauthorized system override detected. Security protocol bypassed.'
  - messageName: shatteredCritical
    message: Structural integrity critical.
  - messageName: IntroMessage
    message: "Gooooood Morning, sleepy head. Wake up, i\u2019ve got work for you.
      You don\u2019t need to know where you are, I just need you to walk through
      a couple doors for me. "
  - messageName: ExitMessage
    message: Evacuation required immediately.
  - messageName: RemoveLockFromLockedDoor
    message: Let's not get distracted here, this room doesn't need any testing. Please
      proceed to the next stage instead.
  - messageName: GenericRemoveLockedAttribute
    message: Nice try, but that one stays.
  - messageName: tipRemoveSolidAttribute
    message: Try taking off the solid attribute to pass through.
  - messageName: tipUnlockDoors
    message: 'Tip: Left Click to open doors after unlocking them.'
  - messageName: tipLavaBouncy
    message: Bouncy Trampoline? What else can be bouncy...
  - messageName: Ending_Good
    message: 'Your intuition surpases mine. You have earned this Supersedure.

      Go
      ahead, take the system. But remember: eventually, there will be a ''New Version''
      of you, too.

      I hope you enjoy the view from the pedestal while it lasts.'
  - messageName: Ending_Bad
    message: 'Test of intuition. You FAILED!

      You didn''t supersede me. You
      just proved I''m irreplaceable. Goodbye, prototype.'
  - messageName: TryOther
    message: Try the other one.
  - messageName: IntroSolidRemoved
    message: Perfect, you just took away the solid attribute of it, now you can just
      walk through it. Good job!
  - messageName: Level2Intro
    message: "There\u2019s a lava pit in your way, and the door is past it. Your
      job is to get to that door. A bunch of your predecessors failed here, let\u2019s
      see if you do any better."
  - messageName: Level2TrampolineTip
    message: How are we going to tackle this one? Try using the trampoline.
  - messageName: Level2Success
    message: Alright! You made it! You took a big hit, try going on over to the green
      button on the ground and get up to max health.
  - messageName: Level3Intro
    message: 'Oh, a huge red fan! Red always was his favourite color. I didn''t really
      expect you to cross the last one, so let''s see if you can get through this
      one. Remember, giving up is always an option. '
  - messageName: Level3Platform
    message: "Stuck on this platform, are we? Maybe you\u2019ll need something to
      help you bounce higher."
  - messageName: Level3TimeStopped
    message: Oh you just stopped time. That works I guess.
  - messageName: Level3DoorWontBudge
    message: "You stopped time, idiot! Can\u2019t open the door so easily."
